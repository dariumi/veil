{
  "productName": "Veil",
  "version": "0.1.0",
  "identifier": "com.veil-project.veil",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Veil",
        "width": 420,
        "height": 680,
        "resizable": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Veil"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Privacy VPN",
    "longDescription": "Veil — censorship-resistant VPN and proxy with HTTP/3 camouflage"
  }
}
